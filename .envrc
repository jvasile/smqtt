#!/bin/bash

VERSION="0.2.0"

collect-bins() {
    # Find any bins in our tree and add them to our path
    pwd=$(pwd)
    bins=$(find "${pwd}" -type d -name "bin" -print 2>/dev/null | xargs | sed "s/ /:/g")
    export PATH=${bins}:${PATH}
}

enable_claude() {
    [ -f .claude/envrc ] && source .claude/envrc
}

_export-env-local() {
    # Read .env.local and export all variables, running pass commands in parallel.
    #
    # For each line in .env.local:
    #   - Lines starting with # or empty lines are skipped.
    #   - If the value looks like a pass command (starts with "pass", optionally
    #     quoted or wrapped in $(...)), the command is run in the background and
    #     the output is exported as the variable value.
    #   - All other lines are exported as-is (literal values, with envsubst
    #     applied for variable references).
    #
    # Note: any variable whose value starts with "pass" (quoted or unquoted)
    # will be treated as a pass command and executed. To store a literal value
    # starting with "pass" without executing it, prefix with "true && ":
    #   VAR=true && pass this is literal
    local env_file=".env.local"
    [ ! -f "$env_file" ] && return

    local tmpdir
    tmpdir=$(mktemp -d -t gemini-XXXXXX)
    trap 'rm -rf -- "$tmpdir"' EXIT

    local pids=()
    local pass_exports_file="$tmpdir/pass_exports" # To collect exports from background tasks

    while IFS= read -r line; do
        if [[ "$line" =~ ^\s*# ]] || [[ -z "$line" ]]; then
            continue
        fi

        local var_name
        var_name="${line%%=*}"
        local command_part
        command_part="${line#*=}"
        local pass_cmd=""

        if [[ "$command_part" =~ ^\"(pass.*)\"$ ]]; then
            pass_cmd="${BASH_REMATCH[1]}"
        elif [[ "$command_part" =~ ^\$\((pass.*)\)$ ]]; then
            pass_cmd="${BASH_REMATCH[1]}"
        elif [[ "$command_part" =~ ^pass.*$ ]]; then
            pass_cmd="$command_part"
        fi

        if [ -n "$pass_cmd" ]; then
            (
                value=$(eval "$pass_cmd")
                printf "export %s=%q\n" "$var_name" "$value" >> "$pass_exports_file"
            ) &
            pids+=($!)
        else
            echo "export $line"
        fi
    done < <(envsubst < "$env_file")

    for pid in "${pids[@]}"; do
        wait "$pid"
    done

    if [ -f "$pass_exports_file" ]; then
        cat "$pass_exports_file"
    fi
}

export-env() {
    # Export all the variables in .env, if it exists
    if [ -f ".env" ]; then
        set -a
        source <(envsubst < .env | grep -v '^#' | grep -v '^$')
        set +a
    fi

    # Export all the variables in .env.local, if it exists
    if [ -f ".env.local" ]; then
        eval "$(_export-env-local)"
    fi
}

run-signed-scripts() {
    # Build set of primary fingerprints for our secret keys
    local my_fps
    my_fps=$(gpg --list-secret-keys --with-colons 2>/dev/null \
        | awk -F: '/^fpr:/{print $10}')

    local sed_marker='^# -\+BEGIN PGP SIGNATURE-\+'
    local sed_end='^# -\+END PGP SIGNATURE-\+'
    local tmp_content tmp_sig status primary_fp

    # Check .env.d in both PWD and the directory .envrc actually lives in
    local envrc_dir
    envrc_dir=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
    local dirs=("$PWD/.env.d")
    [ "$envrc_dir" != "$PWD" ] && dirs+=("$envrc_dir/.env.d")

    local seen=""
    for dir in "${dirs[@]}"; do
        [ -d "$dir" ] || continue
    for script in "$dir"/*; do
        # Deduplicate if both dirs contain the same file (e.g. same dir)
        local real
        real=$(readlink -f "$script")
        case "$seen" in *"$real"*) continue ;; esac
        seen="$seen $real"
        [ -x "$script" ] || continue
        if ! grep -qF -- '# -----BEGIN PGP SIGNATURE-----' "$script"; then
            echo "envrc: skipping $script (unsigned)" >&2
            continue
        fi

        tmp_content=$(mktemp)
        tmp_sig=$(mktemp)

        # Content is everything before the signature
        sed "/$sed_marker/,\$d" "$script" > "$tmp_content"

        # Signature is the commented block, with comment prefixes stripped
        sed -n "/$sed_marker/,/$sed_end/p" "$script" | sed 's/^# //' > "$tmp_sig"

        status=$(gpg --verify --status-fd 1 "$tmp_sig" "$tmp_content" 2>/dev/null)
        rm -f "$tmp_content" "$tmp_sig"

        # Extract primary key fingerprint from VALIDSIG line (last field)
        primary_fp=$(echo "$status" | awk '/^\[GNUPG:\] VALIDSIG /{print $NF}')

        if [ -z "$primary_fp" ]; then
            echo "envrc: skipping $script (tampered or invalid signature)" >&2
        elif echo "$my_fps" | grep -qF "$primary_fp"; then
            source "$script"
        fi
    done
    done
}

# Source local .envrc (can redefine any function above)
[ -f .envrc.local ] && source .envrc.local
run-signed-scripts

collect-bins
export-env

# Local Variables:
# mode: shell-script
# End:
